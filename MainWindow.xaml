<Window x:Class="HelloStickyNotes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HelloStickyNotes"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:controls="clr-namespace:HelloStickyNotes.Controls"
        mc:Ignorable="d"
        WindowStyle="None"
        Topmost="{Binding IsAlwaysOnTop, Mode=OneWay}"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="/Assets/app-icon.ico"
        Title="HelloStickyNotes"
        Height="412" Width="608"
        MinWidth="200" MinHeight="200">
    <!--设置MinWidthMinHeight可避免调整窗口过小时内容显示不佳-->

    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="0" GlassFrameThickness="1" CaptionHeight="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>
    <!--ResizeBorderThickness="6"设置拖拽调整窗口区域的宽度-->

    <Grid>

        <Border CornerRadius="14"
                Background="Bisque" 
                Padding="16"
                BorderThickness="1"
                BorderBrush="Black"
                MouseLeftButtonDown="DragWindow">
            <!--Background="{Binding ThemeColor}"-->
            <!--BorderBrush="{StaticResource BorderSubtleBrush}"-->

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <controls:TitleControl Grid.Row="0"/>
                <controls:NoteListControl Grid.Row="1"/>

                <!--<Border Grid.Row="1">

                    <ListBox ItemsSource="{Binding NoteList}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBox Text="hello"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        FontSize="15"/>
                                    <TextBlock Text="world"
                                        FontFamily="Consolas"
                                        FontSize="14"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                </Border>-->

                <!--<UniformGrid Grid.Row="1" Columns="4" Name="UniformView">
                    <TextBlock Text="111"/>
                    <TextBlock Text="222"/>
                    <TextBlock Text="333"/>
                    <TextBlock Text="111"/>
                    <TextBlock Text="222"/>
                    <TextBlock Text="333"/>
                </UniformGrid>-->

                <GridSplitter Grid.Row="2" Height="1" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="0,0,0,0" Background="Black" Opacity="0.5">
                    <GridSplitter.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="0.001769"/>
                            <!--<TranslateTransform Y="-8"/>-->
                            <TranslateTransform/>
                        </TransformGroup>
                    </GridSplitter.RenderTransform>
                </GridSplitter>

                <StackPanel Orientation="Vertical" Grid.Row="2" Cursor="Hand" Margin="0, 12, 0, 0">
                    <!--<TextBlock Text="111"/>
                    <TextBlock Text="222"/>-->
                    <TextBlock Text="{Binding DebugText}"/>
                    <!--<Label Height="12"></Label>
                    <Button Content="将此窗口置顶" Command="{Binding ToggleAlwaysOnTopCommand}" Style="{StaticResource ThemeButton}"/>-->
                    <Label Height="12"></Label>
                    <Button Content="创建新的便签" Command="{Binding NewNoteCommand}" Style="{StaticResource ThemeButton}"/>
                    <Label Height="12"></Label>
                    <!--<Line Stroke="Black" StrokeThickness="2" HorizontalAlignment="Stretch" X1="0" Y1="0" X2="600" Y2="0" />-->

                    <!--<Label Height="12"></Label>-->
                    <Button Click="TrayItemClose_Click" Style="{StaticResource ThemeButton}">
                        <TextBlock Text="完全关闭" Foreground="#af4040"/>
                    </Button>
                    <!--<WrapPanel>
                        <TextBlock Text="111 "/>
                        <TextBlock Text="222 "/>
                    </WrapPanel>
                    <UniformGrid Columns="3" Rows="6">
                        <Button Content="Text"></Button>
                        <Button></Button>
                        <Button></Button>
                        <Button Content="Text\\nok\nu"></Button>
                    </UniformGrid>-->
                </StackPanel>

                <!--<TextBlock Text="hello world!">
                </TextBlock>-->

                <!--<Button Background="Aqua" Content="tv">
                </Button>-->

                <!--<controls:TitleBarControl Grid.Row="0"/>
                <controls:TimerListControl Grid.Row="1"/>
                <controls:TimerInputControl Grid.Row="2"/>-->
            </Grid>

        </Border>

        <!-- 系统托盘图标 -->
        <tb:TaskbarIcon x:Name="TrayIcon"
            IconSource="/Assets/app-icon.ico"
            ToolTipText="HelloStickyNotes"
            TrayLeftMouseDown="TrayIcon_TrayLeftMouseDown">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="显示窗口" Click="TrayItemShow_Click"/>
                    <MenuItem Header="新建便签" Command="{Binding NewNoteCommand}"/>
                    <Separator/>
                    <MenuItem Header="退出" Click="TrayItemClose_Click"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

    </Grid>


    <!--<tb:TaskbarIcon x:Name="TrayIcon" Grid.Row="0"
                    IconSource="/Assets/app-icon.ico"
            ToolTipText="Equipment Information"
            TrayLeftMouseDown="TrayIcon_TrayLeftMouseDown">
        <tb:TaskbarIcon.ContextMenu>
            <ContextMenu>
                <MenuItem Header="打开主窗口" Click="ShowWindow_Click"/>
                <Separator/>
                <MenuItem Header="退出" Click="ExitApp_Click"/>
            </ContextMenu>
        </tb:TaskbarIcon.ContextMenu>
    </tb:TaskbarIcon>-->

    <!--<Grid Cursor="UpArrow">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="200*"/>
            <ColumnDefinition Width="200*"/>
        </Grid.ColumnDefinitions>
        <Button x:Name="button1" Background="#FFC74343" Width="200" Height="100">
            
        </Button>
    </Grid>-->
</Window>
