<Window x:Class="HelloStickyNotes.NoteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HelloStickyNotes"
        mc:Ignorable="d"
        Title="NoteWindow" Height="180" Width="280"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        AllowsTransparency="True"
        Background="Transparent"
        MinWidth="200" MinHeight="200"
        MaxWidth="1080" MaxHeight="720">

    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="0" GlassFrameThickness="1" CaptionHeight="0" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <!--ShowInTaskbar="False" 不显示在底部导航栏-->
    <Border CornerRadius="14"
        Background="Bisque" 
        Padding="16"
        BorderThickness="1"
        BorderBrush="Black"
        MouseLeftButtonDown="DragWindow">

        <TextBox Name="InputView" 
                 Height="Auto"
                 Text="{Binding Content, UpdateSourceTrigger=PropertyChanged}"
                 Background="Transparent" 
                 TextWrapping="Wrap"
                 BorderThickness="0.0"
                 AcceptsReturn="True"
                 />


    </Border>
</Window>
